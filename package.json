{
  "name": "obsidian-gitlab-inbox",
  "version": "1.0.0",
  "description": "Auto-refreshing GitLab inbox for Obsidian with check-off support.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "gitlab",
    "inbox",
    "code-review"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.8.0"
  }
}
